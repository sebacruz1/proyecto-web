# Secreto JWT — genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=reemplaza_con_un_secreto_largo_y_aleatorio

# Base de datos
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=usuariodb
DB_PASSWORD=clavedb
DB_NAME=muni_sd

# Contraseña root de MySQL (solo para Docker)
MYSQL_ROOT_PASSWORD=root

# Puerto donde se expone la app (solo para Docker, default: 80)
APP_PORT=80

# Puerto del servidor API (desarrollo local)
PORT=3001

# URL base de la API (solo Docker - el frontend la usa en tiempo de build)
VITE_API_BASE_URL=http://localhost:3001

# Orígenes permitidos por CORS (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001,http://localhost,http://18.228.202.160

# Hosts permitidos por CORS (sirve para HTTPS o puertos distintos)
CORS_ALLOWED_HOSTS=localhost,127.0.0.1,18.228.202.160
